# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a long random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to SQLite file (auto-created on first run)
DB_PATH=./taskflow.db

# ─── Groq AI (optional but recommended) ──────────────────────────────────────
# Get your free API key at: https://console.groq.com
# Without this key, the AI assistant panel will show an error but the rest of the app works fine.
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── CORS (production only) ───────────────────────────────────────────────────
# Set to your Render URL in production
# FRONTEND_URL=https://taskflow-xxxx.onrender.com
